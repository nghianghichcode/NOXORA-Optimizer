# NOXORA OPTIMIZER — Line ending normalization
# PowerShell files: CRLF on Windows checkout, LF in repo
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.bat   text eol=crlf

# Data files: LF in repo
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binaries
*.exe   binary
*.dll   binary
*.png   binary
*.zip   binary
